{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Kast",
	"scopeName": "source.kast",
	"fileTypes": [
		"ks"
	],
	"patterns": [
		{
			"include": "#expression"
		}
	],
	"repository": {
		"expression": {
			"patterns": [
				{
					"include": "#strings"
				},
				{
					"include": "#chars"
				},
				{
					"include": "#comments"
				},
				{
					"include": "#block_comments"
				},
				{
					"include": "#curly_brackets"
				},
				{
					"include": "#round_brackets"
				},
				{
					"include": "#square_brackets"
				}
			]
		},
		"curly_brackets": {
			"begin": "\\{",
			"end": "\\}",
			"name": "meta.group.brackets.kast.curly",
			"patterns": [
				{
					"include": "#expression"
				}
			]
		},
		"round_brackets": {
			"begin": "\\(",
			"end": "\\)",
			"name": "meta.group.brackets.kast.round",
			"patterns": [
				{
					"include": "#expression"
				}
			]
		},
		"square_brackets": {
			"begin": "\\[",
			"end": "\\]",
			"name": "meta.group.brackets.kast.square",
			"patterns": [
				{
					"include": "#expression"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double",
					"begin": "\"",
					"end": "\"|$",
					"patterns": [
						{
							"name": "constant.character.escape",
							"contentName": "meta.embedded.kast",
							"begin": "\\\\\\(",
							"end": "\\)",
							"patterns": [
								{
									"include": "#expression"
								}
							]
						},
						{
							"name": "constant.character.escape",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"chars": {
			"patterns": [
				{
					"name": "string.quoted.single",
					"begin": "'",
					"end": "'|$",
					"patterns": [
						{
							"name": "meta.interpolation.kast",
							"begin": "\\\\\\(",
							"end": "\\)",
							"patterns": [
								{
									"include": "#expression"
								}
							]
						},
						{
							"name": "constant.character.escape",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line",
					"begin": "#",
					"end": "$"
				}
			]
		},
		"block_comments": {
			"patterns": [
				{
					"name": "comment.block",
					"begin": "\\(\\#",
					"end": "\\#\\)",
					"patterns": [
						{
							"include": "#block_comments"
						}
					]
				}
			]
		}
	}
}