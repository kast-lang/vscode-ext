{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Kast",
	"scopeName": "source.kast",
	"fileTypes": [
		"ks"
	],
	"patterns": [
		{
			"include": "#expression"
		}
	],
	"repository": {
		"expression": {
			"patterns": [
				{
					"include": "#keywords"
				},
				{
					"include": "#strings"
				},
				{
					"include": "#chars"
				},
				{
					"include": "#comments"
				},
				{
					"include": "#block_comments"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword",
					"match": "\\b(if|while|for|return)\\b"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "meta.interpolation.kast",
							"begin": "\\\\\\(",
							"end": "\\)",
							"patterns": [
								{
									"include": "#expression"
								}
							]
						},
						{
							"name": "constant.character.escape",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"chars": {
			"patterns": [
				{
					"name": "string.quoted.single",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "meta.interpolation.kast",
							"begin": "\\\\\\(",
							"end": "\\)",
							"patterns": [
								{
									"include": "#expression"
								}
							]
						},
						{
							"name": "constant.character.escape",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line",
					"begin": "#",
					"end": "$"
				}
			]
		},
		"block_comments": {
			"patterns": [
				{
					"name": "comment.block",
					"begin": "\\(\\#",
					"end": "\\#\\)",
					"patterns": [
						{
							"include": "#block_comments"
						}
					]
				}
			]
		}
	}
}